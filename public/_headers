# Netlify / Cloudflare Pages headers file.
# Same policy as netlify.toml — duplicated here because some Netlify build
# scenarios prefer the public/_headers file over netlify.toml entries.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'strict-dynamic' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Resource-Policy: same-origin
  X-XSS-Protection: 0

# Private route stricter caching
/signups*
  Cache-Control: no-store, no-cache, must-revalidate, private
/audit-log*
  Cache-Control: no-store, no-cache, must-revalidate, private
/outbox*
  Cache-Control: no-store, no-cache, must-revalidate, private
/security*
  Cache-Control: no-store, no-cache, must-revalidate, private
/my-signup*
  Cache-Control: no-store, no-cache, must-revalidate, private
/badges*
  Cache-Control: no-store, no-cache, must-revalidate, private

/assets/*
  Cache-Control: public, max-age=31536000, immutable
